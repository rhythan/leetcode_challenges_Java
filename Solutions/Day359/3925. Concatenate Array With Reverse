class Solution {
    public int[] concatWithReverse(int[] nums) {

        int[] answer = new int[nums.length*2];
        int end = nums.length-1;
        for(int i = 0 ; i < nums.length ; i ++){
            answer[i] = nums[i];
            answer[i+nums.length]= nums[end--];
        }
        return answer;
    }
}
