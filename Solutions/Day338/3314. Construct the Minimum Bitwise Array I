class Solution {
    public int[] minBitwiseArray(List<Integer> nums) {
        int n = nums.size();
        int[] ans = new int[n];

        for (int i = 0; i < n; i++) {
            int num = nums.get(i);

            if ((num & 1) == 0) {
                ans[i] = -1;
                continue;
            }

            int x = num;

            int bit = 0;
            while ((x & 1) == 1) {
                x >>= 1;
                bit++;
            }

            ans[i] = num ^ (1 << (bit - 1));
        }

        return ans;
    }
}
