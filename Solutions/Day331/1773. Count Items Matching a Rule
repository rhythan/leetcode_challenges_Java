class Solution {
    public int countMatches(List<List<String>> items, String ruleKey, String ruleValue) {
        
        int cnt = 0, k = 2;

        if(ruleKey.equals("type")) k = 0;
        else if(ruleKey.equals("color")) k = 1;

        for(int j = 0; j < items.size(); j++) {
            if(items.get(j).get(k).equals(ruleValue)) {
                cnt++;
            }
        }

        return cnt;
    }
}
