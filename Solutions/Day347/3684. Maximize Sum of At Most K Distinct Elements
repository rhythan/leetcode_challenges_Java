class Solution {
    public int[] maxKDistinct(int[] nums, int k) {
        
        Arrays.sort(nums);

        List<Integer> list = new ArrayList<>();

        for(int i = nums.length - 1 ; i >= 0 && list.size() < k ; i--){

            if(i == nums.length - 1 || nums[i] != nums[i + 1]){
                list.add(nums[i]);
            }
        }

        int[] answer = new int[list.size()];

        for(int i = 0 ; i < list.size() ; i++){
            answer[i] = list.get(i);
        }

        return answer;
    }
}
