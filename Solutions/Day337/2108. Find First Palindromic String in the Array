class Solution {
    public String firstPalindrome(String[] words) {
        for(String word : words){
            if(check(word)) return word ;
        }
        return "";
    }
    boolean check(String str){
        int left = 0 , right = str.length()-1;
        while(left<right){
            if(str.charAt(left)!=str.charAt(right)){
                return false ;
            }
            left++;
            right--;
        }
        return true ;
    }
}
