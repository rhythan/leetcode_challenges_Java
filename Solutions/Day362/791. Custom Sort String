class Solution {
    public String customSortString(String order, String s) {
        int[] freq = new int[26];

        for (char ch : s.toCharArray()) {
            freq[ch - 'a']++;
        }

        StringBuilder sb = new StringBuilder();

        // Add characters according to order
        for (char ch : order.toCharArray()) {
            while (freq[ch - 'a'] > 0) {
                sb.append(ch);
                freq[ch - 'a']--;
            }
        }

        // Add remaining characters
        for (int i = 0; i < 26; i++) {
            while (freq[i] > 0) {
                sb.append((char) (i + 'a'));
                freq[i]--;
            }
        }

        return sb.toString();
    }
}
