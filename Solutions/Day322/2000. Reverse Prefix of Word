class Solution {
    public String reversePrefix(String word, char ch) {
        StringBuilder sb = new StringBuilder();
        int start = 0 , end = 0 ;
        for(int i = 0 ; i < word.length() ; i ++){
            if(ch==word.charAt(i)){
                end = i ;
                break;
            }
        }
        if(end==0) return word ;
        for(int i = end ; i >= 0 ; i --){
            sb.append(word.charAt(i));
        }
        for(int i = end+1 ; i < word.length() ; i ++){
            sb.append(word.charAt(i));
        }
        return sb.toString();
    }
}
