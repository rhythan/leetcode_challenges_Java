class Solution {
    public List<Integer> findMissingElements(int[] nums) {
        Arrays.sort(nums);
        List<Integer> list = new ArrayList<>();
        int left = nums[0] ,  right = nums[ nums.length - 1] , j = 0;
        for(int i = left  ; i <= right ; i ++){
            if(nums[j]==i) j++;
            else list.add(i);
        }
        return list ;
    }
}
