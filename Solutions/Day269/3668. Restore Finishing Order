class Solution {
    public int[] recoverOrder(int[] order, int[] friends) {
            int[] ans = new int[friends.length];
            int x = 0 ;
            for(int i = 0 ; i < order.length ; i ++){
                if(check(order[i],friends)){
                    ans[x++]=order[i];
                }
            }
            return ans;
    }
    boolean check(int num , int[] arr){
        for(int n : arr) if(n==num) return true;        
        return false;
    }
}
