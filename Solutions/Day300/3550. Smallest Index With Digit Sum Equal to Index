class Solution {
    public int smallestIndex(int[] nums) {
        int min = Integer.MAX_VALUE;
        for(int i = 0 ; i < nums.length ; i ++){
            if(i==sum(nums[i])){
                if(i<min){
                    min = i ;
                }
            }
        }
        return (min==Integer.MAX_VALUE)?-1:min;
    }
    int sum(int n){
        int ans = 0 ;
        while(n>0){
            ans+=n%10;
            n/=10;
        }
        return ans ;
    }
}
