class Solution {
    public boolean isBalanced(String num) {
        
        int even = 0 , odd = 0 ;
         for(int i = 0 ; i < num.length() ; i ++){
            if(i%2==0){
                even += (int)num.charAt(i) - '0';
               
            }
            else{
                odd += (int)num.charAt(i) - '0';

            }
         }
         return even==odd;
    }
}
