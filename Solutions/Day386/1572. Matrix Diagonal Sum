class Solution {
    public int diagonalSum(int[][] mat) {
        int sum = 0 ;
        for(int i = 0 ; i < mat.length ; i ++){
            sum+=mat[i][i];
        }
        int row = 0 , col = mat.length - 1 ;
        while(row < mat.length && col >= 0 ){
            sum+=mat[row][col];
            row++;
            col--;
        }
        if(mat.length%2 != 0 ){
            sum-=mat[mat.length/2][mat.length/2];
        }
        return sum;
    

    }
}
