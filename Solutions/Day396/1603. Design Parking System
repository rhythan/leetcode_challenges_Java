class ParkingSystem {
    int B , M , S ;

    public ParkingSystem(int big, int medium, int small) {
        B = big ;
         M = medium ;
          S = small ;
    }
    
    public boolean addCar(int carType) {
        if(carType == 1){
            if(B>0) {
                B-=1;
                return true;
            }
            else{
                return false ;
            }
        }
        else if (carType == 2){
            if(M>0){
                M-=1;
                return true ;
            }
            else {
                return false ;
            }
        }
        else{
            if(S>0){
                S-=1;
                return true ;
            }
            else{
                return false ;
            }
        }
        
    }
}

