class Solution {
    public int countDigitOccurrences(int[] nums, int digit) {
        int cnt = 0 ;
        for(int num : nums){
            cnt+=check(num , digit);
        }
        return cnt ;
        
    }
    int check(int num , int digit ){
        int cnt = 0 ;
        while(num>0){
            if(num%10 == digit) cnt++;
            num/=10;
        }
        return cnt ;
    }
}
