class Solution {
    public int minSteps(String s, String t) {
        HashMap<Character,Integer> tt = new HashMap<>();
        int[] freq = new int[26];
        for(char ch : s.toCharArray()){
            freq[ch-'a']++;
        }
         for(char ch : t.toCharArray()){
            freq[ch-'a']--;
        }
        int ans = 0 ;
        for(int n : freq){
            if(n>0){
                ans+=n;
            }
        }
        
        
    
        return ans ;
        

        
    }
}
