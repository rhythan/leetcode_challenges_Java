class Solution {
    public int digitFrequencyScore(int n) {
        int sum = 0 ;
        Map<Integer,Integer> map = new HashMap<>();
        while(n>0){
            int num = n%10 ;
            map.put(num,map.getOrDefault(num,0)+1);
            n/=10;
        }
        for(Map.Entry<Integer,Integer> e : map.entrySet()){
            sum+=(e.getKey()*e.getValue());
        }
        return sum ;
    }
}
